# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# =============================================================================

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HRM Skate Spots

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL (public)
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (public — safe for browser, RLS enforced)
# Get from: Supabase Dashboard → Project Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SECRET — server-side only, bypasses RLS)
# Get from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Direct database connection string (server-side only)
DATABASE_URL=

# -----------------------------------------------------------------------------
# Google Gemini AI (Spot Finder feature)
# -----------------------------------------------------------------------------
# Free tier: 1,500 requests/day — no credit card required
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (Payments - test mode)
# -----------------------------------------------------------------------------
# Use test keys from Stripe Dashboard (Developers > API keys)
STRIPE_SECRET_KEY=

# Price ID for your recurring premium plan (for Stripe Checkout)
# Example: price_12345abcde
STRIPE_PRICE_ID=

# Optional for future webhook support
STRIPE_WEBHOOK_SECRET=
